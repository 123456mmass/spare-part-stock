generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineUserId String?  @unique
  lineAccounts LineAccount[]
  movements  StockMovement[]
}

model LineAccount {
  id         String   @id @default(cuid())
  lineUserId String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

enum Role {
  ADMIN
  STAFF
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parts Part[]
}

model Building {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parts Part[]
}

model Part {
  id              String   @id @default(cuid())
  partNumber      String   @unique
  partName        String
  description     String?
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  buildingId      String?
  building        Building? @relation(fields: [buildingId], references: [id])
  subcategory     String?
  plant           String?
  createdBy       String?
  location        String?
  quantity        Int      @default(0)
  minimumQuantity Int      @default(0)
  unit            String   @default("pcs")
  imageUrl        String?
  imageEmbedding  Bytes?
  qrCodeUrl       String?
  barcodeValue    String?   @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  movements StockMovement[]

  @@index([partNumber])
  @@index([categoryId])
  @@index([buildingId])
  @@index([location])
  @@index([partName])
  @@index([plant])
}

model StockMovement {
  id              String       @id @default(cuid())
  partId          String
  part            Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  type            MovementType
  quantityBefore  Int
  quantityAfter   Int
  quantityChange  Int
  note            String?
  createdAt       DateTime     @default(now())

  @@index([partId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

enum MovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
}

model Conversation {
  id          String   @id @default(cuid())
  lineUserId  String?  // null for group-only conversations
  lineGroupId String?  // null for 1-on-1 conversations
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages ConversationMessage[]

  @@index([lineUserId])
  @@index([lineGroupId])
  @@index([updatedAt])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // "user" | "assistant" | "system"
  content        String
  messageType    String   @default("text")  // "text" | "image" | "command"
  metadata       String?  // JSON: tool calls, image URLs, import state, etc
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}
